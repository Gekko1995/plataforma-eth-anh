# ============================================================
# VARIABLES DE ENTORNO - Plataforma ETH-ANH 2026
# ============================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores de ejemplo con tus valores reales
# 3. NUNCA commits .env al repositorio git
# ============================================================

# ──────────────────────────────────────────────────────────
# ENTORNO
# ──────────────────────────────────────────────────────────
NODE_ENV=production
# Valores: development | production

# ──────────────────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────────────────
PORT=3000
# Puerto en el que corre el servidor Express

# ──────────────────────────────────────────────────────────
# CORS - DOMINIOS PERMITIDOS
# ──────────────────────────────────────────────────────────
# Lista de dominios separados por comas (sin espacios)
ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# Ejemplos:
# ALLOWED_ORIGINS=https://plataforma-eth-anh.com,https://www.plataforma-eth-anh.com
# ALLOWED_ORIGINS=https://convenio2026.fwrts.org,https://sinapsis3d.com

# ⚠️ NUNCA uses esto en producción:
# ALLOWED_ORIGINS=*

# ──────────────────────────────────────────────────────────
# GOOGLE APPS SCRIPT (Autenticación)
# ──────────────────────────────────────────────────────────
# URL del Google Apps Script usado por el SERVIDOR para autenticar usuarios.
# El servidor proxea las credenciales a este endpoint (nunca se expone al navegador).
APPS_SCRIPT_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec

# URL expuesta al cliente React para mostrar el banner de "modo demo".
# Debe coincidir con APPS_SCRIPT_URL cuando el script esté configurado.
REACT_APP_APPS_SCRIPT_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec

# Si dejas esto vacío, se usan usuarios locales de prueba (solo en NODE_ENV=development)

# ──────────────────────────────────────────────────────────
# GOOGLE SHEETS (Gestión de usuarios)
# ──────────────────────────────────────────────────────────
# URL de la hoja de cálculo donde se gestionan los usuarios de la plataforma.
# Solo visible para administradores dentro de la aplicación.
REACT_APP_USERS_SHEET_URL=https://docs.google.com/spreadsheets/d/TU_SHEET_ID/edit

# ──────────────────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────────────────
# Máximo de requests permitidos por ventana de tiempo
RATE_LIMIT_MAX=100

# Ventana de tiempo en minutos
RATE_LIMIT_WINDOW_MINUTES=15

# ──────────────────────────────────────────────────────────
# SSL/TLS (Para producción)
# ──────────────────────────────────────────────────────────
# Rutas a certificados SSL (solo si usas HTTPS en Express)
# SSL_CERT_PATH=/etc/letsencrypt/live/tu-dominio.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/tu-dominio.com/privkey.pem

# ──────────────────────────────────────────────────────────
# LOOKER STUDIO
# ──────────────────────────────────────────────────────────
# URL del dashboard de Looker Studio embebido
LOOKER_DASHBOARD_URL=https://lookerstudio.google.com/embed/reporting/TU_REPORT_ID/page/TU_PAGE_ID

# ──────────────────────────────────────────────────────────
# LOGGING (Opcional)
# ──────────────────────────────────────────────────────────
# Nivel de logging: error | warn | info | debug
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────
# MONITOREO (Opcional)
# ──────────────────────────────────────────────────────────
# Sentry DSN para tracking de errores
# SENTRY_DSN=https://tu-sentry-dsn@sentry.io/proyecto-id

# Google Analytics ID
# GA_TRACKING_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────────────
# DESARROLLO (Solo usar en desarrollo local)
# ──────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# NODE_ENV=development
